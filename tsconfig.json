{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["node", "vscode", "vitest/globals"],
    "jsx": "react-jsx",
    "allowJs": true,
    "checkJs": false
  },
  "files": ["src/extension.ts", "src/webview/editor.ts"],
  "include": ["src/**/*.test.ts", "src/types/**/*.d.ts"]
}
